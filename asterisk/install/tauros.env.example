# Copie para tauros.env e preencha antes de instalar.
# Nao commite tauros.env preenchido.

PUBLIC_IP="SEU_IP_PUBLICO_DA_VPS_ASTERISK"

# Dominio opcional usado pelo painel/WebRTC. Pode ficar vazio.
ASTERISK_DOMAIN=""

# IP publico do servidor onde esta o painel Tauros.
# O AMI ficara restrito a este IP.
PANEL_AMI_ALLOW_IP="IP_DO_PAINEL"

AMI_USER="discadora_panel"
AMI_SECRET="TROQUE_POR_SENHA_FORTE"
AMI_PORT="5038"

# WebSocket HTTP do Asterisk.
HTTP_PORT="8088"

# RTP.
RTP_START="10000"
RTP_END="20000"

# Tronco MagnusBilling.
MAGNUS_HOST="IP_OU_DOMINIO_MAGNUS"
MAGNUS_PORT="5060"
MAGNUS_USER="USUARIO_MAGNUS"
MAGNUS_SECRET="SENHA_MAGNUS"
MAGNUS_FROM_USER="USUARIO_MAGNUS"
MAGNUS_FROM_DOMAIN="IP_OU_DOMINIO_MAGNUS"

# Bina padrao se a chamada nao enviar uma bina especifica.
DEFAULT_CALLERID="18997454428"

# TURN opcional. 1 instala/configura coturn, 0 pula.
INSTALL_TURN="1"
TURN_REALM="tauros.local"
TURN_USER="tauros"
TURN_SECRET="TROQUE_POR_SENHA_FORTE_TURN"
TURN_PORT="3478"

# Firewall opcional via ufw. 1 aplica regras basicas, 0 nao mexe.
CONFIGURE_UFW="1"

